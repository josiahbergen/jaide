{
    "files.exclude": {

        // defaults
        "**/.git": true,
        "**/.svn": true,
        "**/.hg": true,
        "**/.DS_Store": true,
        "**/Thumbs.db": true,
        
        // python
        "**/__pycache__": true,
        "**.pytest_cache": true,
        "**/__init__.py": true,
        "pyproject.toml": true,
        "uv.lock": true,
        
        // stuff i dont wanna be seeing
        "**/.vscode/": true,
        "**/.zed/": true,
        ".gitignore": true,

        // llm helpers
        "**.claude": true,
        "CLAUDE.md": true
    },
}