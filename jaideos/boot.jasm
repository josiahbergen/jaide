; jaide bootloader
; josiah bergen, march 2026

org 0x0000

start:
    ; bootloader entry point. lives at 0x0000.
    mov sp, 0xfdff
    
    ; todo: load kernel into ram with manual mmio writes
    jmp kernel__main

align 0x100 ; fill entire rom

; kernel, "loaded" at 0x100
import "os/kernel/kernel.jasm"
