// Folder-specific settings
//
// For a full list of overridable settings, and general information on folder-specific settings,
// see the documentation: https://zed.dev/docs/configuring-zed#settings-files
{
  "file_scan_exclusions": [
    // defaults
    "**/.git",
    "**/.svn",
    "**/.hg",
    "**/.jj",
    "**/.repo",
    "**/CVS",
    "**/.DS_Store",
    "**/Thumbs.db",
    "**/.classpath",
    "**/.settings",

    // python artifacts and env things
    "**/__pycache__/",
    "**/.pytest_cache/",
    "**/__init__.py",
    ".python-version",
    // "pyproject.toml",
    "uv.lock",

    // custom stuff
    ".venv",
    ".vscode",
    ".gitignore",

    // llm tools
    "CLAUDE.md",
    ".claude",
  ],

  "format_on_save": "on",
}
